rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only read/write their own documents
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Notes subcollection - private per-user notes
      match /notes/{noteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Daily log subcollection - private per-user daily log entries
      match /dailylog/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Flashcards subcollection - private per-user cards
      match /flashcards/{cardId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Flashcard progress subcollection - private per-user progress
      match /flashcardProgress/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Flashcard decks - private per-user spaced repetition decks
      match /flashcardDecks/{deckId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Deck cards - SR state per card per deck
        match /deckCards/{cardId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Review sessions - private per-user session history for streak tracking
      match /reviewSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Daily streak - private per-user streak tracking (single document)
      match /dailyStreak {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Baby milestones subcollection - private per-user milestone photos metadata
      match /babyMilestones/{stageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Cloud files subcollection - private per-user file metadata
      match /files/{fileId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Benchmark endpoints subcollection - private per-user endpoints
      match /benchmarkEndpoints/{endpointId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Benchmark runs subcollection - private per-user benchmark history
      match /benchmarkRuns/{runId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Hiking routes subcollection - private per-user saved routes
      match /hikingRoutes/{routeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Immigration cases subcollection - private per-user case tracking
      match /immigrationCases/{caseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Game progress subcollection - private per-user game stats
      match /gameProgress/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Children subcollection - private per-user child profiles
      match /children/{childId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Trips subcollection - private per-user trip planning
      match /trips/{tripId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Travel pins subcollection - private per-user map pins
      match /travelPins/{pinId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Crawl jobs subcollection - private per-user web crawler jobs
      match /crawlJobs/{jobId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Crawled documents subcollection
        match /documents/{docId} {
          allow read: if request.auth != null && request.auth.uid == userId;
        }

        // Crawl trace/log subcollection
        match /traces/{traceId} {
          allow read: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // Public hiking routes - authenticated read/create, creator-only delete
    match /publicHikingRoutes/{routeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.sharedBy.uid == request.auth.uid;
    }

    // Feedback collection - anyone can submit feedback (write-only inbox)
    match /feedback/{feedbackId} {
      allow create: if request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 5000
        && request.resource.data.category in ['general', 'bug', 'feature', 'other']
        && request.resource.data.rating is number
        && request.resource.data.rating >= 0
        && request.resource.data.rating <= 5;
    }

    // Public notes - any authenticated user can read/write
    match /publicNotes/{noteId} {
      allow read, write: if request.auth != null;
    }

    // Worship songs - public read, authenticated write
    match /worshipSongs/{songId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Chinese characters - public read, authenticated write (legacy, kept during migration)
    match /chineseCharacters/{charId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Public flashcards - public read, authenticated write
    match /publicFlashcards/{cardId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Shared files - authenticated read, creator can delete
    match /sharedFiles/{fileId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.sharedBy.uid == request.auth.uid;
    }

    // Announcements - public read, admin-only write (via Firebase console/backend)
    match /announcements/{announcementId} {
      allow read: if true;
    }

    // API Keys - server-only (Cloud Functions access via Admin SDK, deny all client access)
    match /apiKeys/{keyHash} {
      allow read, write: if false;
    }

    // Game scores - shared scoreboard, any authenticated user can read/write
    // Scores stored as games/scores/{gameType}/{scoreId} (subcollection per game type)
    match /games/scores/{gameType}/{scoreId} {
      allow read, write: if request.auth != null;
    }

    // Polls - public read, authenticated create, creator can delete
    match /polls/{pollId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }

    // Books - shared library, authenticated read, uploader can write/delete
    match /books/{bookId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.uploadedBy.uid == request.auth.uid;

      // Chapters subcollection - authenticated read only (written by cloud function)
      match /chapters/{chapterId} {
        allow read: if request.auth != null;
      }
    }
  }
}
