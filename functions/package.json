{
  "name": "weather-functions",
  "version": "1.0.0",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "pnpm build && firebase emulators:start --only functions",
    "shell": "pnpm build && firebase functions:shell",
    "start": "pnpm shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@apollo/server": "^5.2.0",
    "@as-integrations/express4": "^1.1.2",
    "@google-cloud/functions-framework": "^5.0.1",
    "@google/genai": "^1.44.0",
    "@graphql-tools/schema": "^10.0.31",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.1.0",
    "graphql": "^16.13.1",
    "graphql-depth-limit": "^1.1.0",
    "graphql-subscriptions": "^3.0.0",
    "node-cache": "^5.1.2",
    "openai": "^4.73.0",
    "epub2": "^3.0.2",
    "@google-cloud/text-to-speech": "^5.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "typescript": "^5.3.3",
    "vitest": "^4.0.17"
  },
  "pnpm": {
    "overrides": {
      "ajv": ">=8.18.0",
      "fast-xml-parser": ">=5.3.6"
    }
  }
