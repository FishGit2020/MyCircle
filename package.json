  "scripts": {
    "dev": "pnpm build:remotes && concurrently -n server,shell,city,weather,stock,podcast,ai,bible,worship,notebook,baby,child-dev,chinese,english,flashcards,daily-log,cloud-files,benchmark,immigration,library,games,doc-scan,hiking,trip,polls,radio,interview,transit,travel,deals,crawler,resume,setup -c blue,green,yellow,magenta,cyan,white,red,#d97706,#8b5cf6,#10b981,#ec4899,#14b8a6,#f59e0b,#6366f1,#f97316,#a855f7,#06b6d4,#84cc16,#e11d48,#0ea5e9,#d946ef,#9333ea,#22c55e,#fb923c,#7c3aed,#f59e0b,#c084fc,#2dd4bf,#059669,#10b981,#0284c7,#6d28d9,#475569 \"pnpm dev:server\" \"pnpm dev:shell\" \"pnpm preview:city\" \"pnpm preview:weather\" \"pnpm preview:stock\" \"pnpm preview:podcast\" \"pnpm preview:ai\" \"pnpm preview:bible\" \"pnpm preview:worship\" \"pnpm preview:notebook\" \"pnpm preview:baby\" \"pnpm preview:child-dev\" \"pnpm preview:chinese\" \"pnpm preview:english\" \"pnpm preview:flashcards\" \"pnpm preview:daily-log\" \"pnpm preview:cloud-files\" \"pnpm preview:benchmark\" \"pnpm preview:immigration\" \"pnpm preview:digital-library\" \"pnpm preview:family-games\" \"pnpm preview:doc-scanner\" \"pnpm preview:hiking\" \"pnpm preview:trip-planner\" \"pnpm preview:poll-system\" \"pnpm preview:radio-station\" \"pnpm preview:ai-interviewer\" \"pnpm preview:transit-tracker\" \"pnpm preview:travel-map\" \"pnpm preview:deal-finder\" \"pnpm preview:web-crawler\" \"pnpm preview:resume-tailor\" \"pnpm preview:setup\"",
