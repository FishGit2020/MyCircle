    "preview:resume-tailor": "pnpm --filter @mycircle/resume-tailor preview",
    "preview:setup": "pnpm --filter @mycircle/setup preview",
    "build:remotes": "pnpm --filter '!@mycircle/shell' --filter '!@mycircle/shared' -r --parallel build",
    "dev:mf": "concurrently \"pnpm dev:shell\" \"pnpm preview:city\" \"pnpm preview:weather\" \"pnpm preview:stock\" \"pnpm preview:podcast\" \"pnpm preview:ai\" \"pnpm preview:bible\" \"pnpm preview:worship\" \"pnpm preview:notebook\" \"pnpm preview:baby\" \"pnpm preview:child-dev\" \"pnpm preview:chinese\" \"pnpm preview:english\" \"pnpm preview:flashcards\" \"pnpm preview:daily-log\" \"pnpm preview:cloud-files\" \"pnpm preview:benchmark\" \"pnpm preview:immigration\" \"pnpm preview:digital-library\" \"pnpm preview:family-games\" \"pnpm preview:doc-scanner\" \"pnpm preview:hiking\" \"pnpm preview:trip-planner\" \"pnpm preview:poll-system\" \"pnpm preview:radio-station\" \"pnpm preview:ai-interviewer\" \"pnpm preview:transit-tracker\" \"pnpm preview:travel-map\" \"pnpm preview:deal-finder\" \"pnpm preview:web-crawler\" \"pnpm preview:resume-tailor\" \"pnpm preview:setup\"",
    "build": "pnpm build:shared && pnpm build:mf",
    "codegen": "node scripts/extract-schema.mjs && node -e \"var fs=require('fs');if(fs.existsSync('schema.graphql')){require('child_process').execSync('graphql-codegen --config codegen.ts',{stdio:'inherit'})}\"",
    "build:shared": "pnpm codegen && pnpm --filter @mycircle/shared build",
    "build:mf": "pnpm --filter @mycircle/shell build && pnpm --filter '!@mycircle/shell' --filter '!@mycircle/shared' -r --parallel build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "start:static": "node scripts/serve-static.mjs",
    "preview": "cross-env NODE_ENV=production tsx server/index.ts",
    "lint": "eslint packages/ --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "pnpm -r typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mf": "pnpm --filter '!mycircle' -r --parallel test:run",
    "test:all": "pnpm test:run && pnpm test:mf",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test --config playwright.smoke.config.ts",
    "test:e2e:emulator": "playwright test --config playwright.emulator.config.ts",
    "mock-api": "node scripts/mock-api-server.mjs",
    "emulator:seed-and-test": "pnpm test:e2e:emulator",
    "emulator:exec": "firebase emulators:exec --only functions,hosting,firestore,auth \"pnpm emulator:seed-and-test\"",
    "emulator:test": "concurrently -k -s first \"pnpm mock-api\" \"pnpm emulator:exec\"",
    "firebase:build": "pnpm build:shared && pnpm firebase:build:mf && pnpm firebase:build:functions && pnpm firebase:assemble",
    "firebase:build:mf": "cross-env NODE_ENV=production pnpm --filter @mycircle/shell build && cross-env NODE_ENV=production pnpm --filter '!@mycircle/shell' --filter '!@mycircle/shared' -r --parallel build",
    "firebase:build:functions": "cd functions && rm -rf node_modules && npm install && npx tsc",
    "firebase:assemble": "node scripts/assemble-firebase.mjs",
    "firebase:deploy": "pnpm firebase:build && firebase deploy",
    "firebase:deploy:hosting": "pnpm firebase:build && firebase deploy --only hosting",
    "firebase:deploy:functions": "pnpm firebase:build:functions && firebase deploy --only functions",
    "firebase:emulators": "pnpm firebase:build && firebase emulators:start",
    "firebase:login": "firebase login",
    "cap:build": "pnpm build:shared && pnpm firebase:build:mf && pnpm firebase:assemble && npx cap sync",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open ios",
    "analyze": "cross-env ANALYZE=true pnpm --filter @mycircle/shell build",
    "changelog": "node scripts/generate-changelogs.mjs",
    "check:shared-versions": "node scripts/check-shared-versions.mjs",
    "new-spec": "node scripts/new-spec.mjs",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist dist functions/node_modules functions/lib",
    "clean:install": "pnpm clean && pnpm install",
    "postinstall": "pnpm codegen",
    "prepare": "husky"
  },
