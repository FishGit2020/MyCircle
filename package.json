    "preview:city": "pnpm --filter @mycircle/city-search preview",
    "preview:weather": "pnpm --filter @mycircle/weather-display preview",
    "preview:stock": "pnpm --filter @mycircle/stock-tracker preview",
    "preview:podcast": "pnpm --filter @mycircle/podcast-player preview",
    "preview:ai": "pnpm --filter @mycircle/ai-assistant preview",
    "preview:bible": "pnpm --filter @mycircle/bible-reader preview",
    "preview:worship": "pnpm --filter @mycircle/worship-songs preview",
    "preview:notebook": "pnpm --filter @mycircle/notebook preview",
    "preview:baby": "pnpm --filter @mycircle/baby-tracker preview",
    "preview:child-dev": "pnpm --filter @mycircle/child-development preview",
    "preview:chinese": "pnpm --filter @mycircle/chinese-learning preview",
    "preview:english": "pnpm --filter @mycircle/english-learning preview",
