    "preview:hiking": "pnpm --filter @mycircle/hiking-map preview",
    "preview:trip-planner": "pnpm --filter @mycircle/trip-planner preview",
    "preview:poll-system": "pnpm --filter @mycircle/poll-system preview",
    "preview:radio-station": "pnpm --filter @mycircle/radio-station preview",
    "preview:ai-interviewer": "pnpm --filter @mycircle/ai-interviewer preview",
    "preview:transit-tracker": "pnpm --filter @mycircle/transit-tracker preview",
